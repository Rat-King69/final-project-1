def create_ik_arm():
    sel = cmds.ls(sl=True, type='joint')
    ik_joints = [jnt for jnt in sel if 'IK_JNT' in jnt]

    # get start and end joint
    start_jnt = ik_joints[0]
    end_jnt = ik_joints[-1]

    # create ik handle
    ik_handle, ik_effector = cmds.ikHandle(
        name='L_arm_IKH',
        startJoint=start_jnt,
        endEffector=end_jnt,
        solver='ikRPsolver'
    )

    # create nurbs circle
    ik_ctrl = cmds.circle(name=end_jnt.replace('_IK_JNT', '_IK_CON'), normal=[1, 0, 0], radius=1, constructionHistory=False)[0]

    # group the nurbs circle
    ik_ctrl_grp = cmds.group(ik_ctrl, name=end_jnt.replace('_IK_JNT', '_GRP'))

    # parent constraint with offset off to snap group to end joint
    constraint = cmds.parentConstraint(end_jnt, ik_ctrl_grp, maintainOffset=False)

    # delete the constraint
    cmds.delete(constraint)

    # parent ik handle under the wrist control
    cmds.parent(ik_handle, ik_ctrl)

def create_fk_ik_switch():
    sel = cmds.ls(sl=True)
    switch_ctrl = sel[0]
    bind_joints = sel[1:]

    # add FK/IK blend attribute to switch control (0 = FK, 1 = IK)
    cmds.addAttr(switch_ctrl, longName='FK_IK', attributeType='float', min=0, max=1, defaultValue=0, keyable=True)

    for jnt in bind_joints:
        # create pair blend node to blend between FK and IK
        pair_blend = cmds.createNode('pairBlend', name=jnt.replace('_JNT', '_PB'))

        # set pair blend to rotate mode
        cmds.setAttr(pair_blend + '.rotInterpolation', 1)

        # connect FK joint rotations to input1
        cmds.connectAttr(jnt.replace('_JNT', '_FK_JNT') + '.rotate', pair_blend + '.inRotate1')

        # connect IK joint rotations to input2
        cmds.connectAttr(jnt.replace('_JNT', '_IK_JNT') + '.rotate', pair_blend + '.inRotate2')

        # connect pair blend output to bind joint
        cmds.connectAttr(pair_blend + '.outRotate', jnt + '.rotate')

        # connect FK/IK attribute to pair blend weight
        cmds.connectAttr(switch_ctrl + '.FK_IK', pair_blend + '.weight')





create_fk_ik_switch()
